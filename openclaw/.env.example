GROKSEARCH_MCP_BASE_URL=https://search.example.com
GROKSEARCH_MCP_BEARER_TOKEN=your-token

# Optional: override the derived MCP URL if your path is not /mcp
# GROKSEARCH_MCP_URL=https://search.example.com/mcp

# Optional: explicit health URL if it is not next to /mcp
# GROKSEARCH_HEALTH_URL=https://search.example.com/health

# Optional: override the default HTTP user agent
# GROKSEARCH_HTTP_USER_AGENT=GrokSearch-OpenClaw/0.2
